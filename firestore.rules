rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidLogEntry(data) {
      return data.userId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.type in ['film', 'series']
        && (data.rating == null || (data.rating is number && data.rating >= 0 && data.rating <= 10))
        && (data.company == null || (data.company is string && data.company.size() <= 100))
        && (data.thumbnail_url == null || (data.thumbnail_url is string && data.thumbnail_url.size() <= 1000))
        && (data.watched_on == null || (data.watched_on is string && data.watched_on.size() <= 100))
        && data.date_watched is string // simplified date string check
        && data.createdAt is timestamp || data.createdAt is string
        && data.updatedAt is timestamp || data.updatedAt is string;
    }

    function isValidUserProfile(data) {
      return data.uid == request.auth.uid
        && (data.email == null || (data.email is string && data.email.size() <= 255))
        && (data.updatedAt is timestamp || data.updatedAt is string);
    }

    // --- Collections ---

    match /logs/{logId} {
      allow create: if isSignedIn() && isValidId(logId) && isValidLogEntry(incoming());
      
      allow read, update, delete: if isSignedIn() && isOwner(existing().userId);

      allow update: if (
        isSignedIn() 
        && isOwner(existing().userId)
        && isValidLogEntry(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
      );
    }

    match /users/{userId} {
      allow create: if isSignedIn() && isOwner(userId) && isValidUserProfile(incoming());
      
      allow read: if isSignedIn() && isOwner(userId);

      allow update: if (
        isSignedIn() 
        && isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().uid == existing().uid
      );
    }
  }
}
